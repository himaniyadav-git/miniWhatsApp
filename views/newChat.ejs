<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Write new Chats</title>
</head>
<body>
    <h3>Write new Chats</h3>
    <form action="/chats" method="POST">
